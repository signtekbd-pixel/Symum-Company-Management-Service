generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Roles & Permissions ─────────────────────────────────────────────────────

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id        String   @id @default(cuid())
  module    String   // e.g. "orders", "inventory", "customers"
  action    String   // e.g. "create", "read", "update", "delete"
  roles     Role[]
  createdAt DateTime @default(now())

  @@unique([module, action])
}

// ─── Users & Auth ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  avatar        String?
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])
  branchId      String?
  branch        Branch?   @relation(fields: [branchId], references: [id])
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
  proofReviews  Proof[]
  productionJobs ProductionJob[]

  @@index([email])
  @@index([roleId])
}

// ─── Branches / Locations ────────────────────────────────────────────────────

model Branch {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  address     String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true)
  users       User[]
  orders      Order[]
  materials   Material[]
  warehouses  Warehouse[]
  machines    Machine[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id              String          @id @default(cuid())
  name            String
  email           String?
  phone           String
  altPhone        String?
  company         String?
  address         String?
  city            String?
  type            CustomerType    @default(INDIVIDUAL)
  creditLimit     Decimal         @default(0) @db.Decimal(12, 2)
  currentBalance  Decimal         @default(0) @db.Decimal(12, 2)
  notes           String?
  isActive        Boolean         @default(true)
  orders          Order[]
  invoices        Invoice[]
  proofs          Proof[]
  deliveryAddresses DeliveryAddress[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([phone])
  @@index([email])
  @@index([name])
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
  CORPORATE
}

model DeliveryAddress {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  label      String   // e.g. "Office", "Home", "Warehouse"
  address    String
  city       String?
  contact    String?
  phone      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Products & Pricing ──────────────────────────────────────────────────────

model ProductCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id              String          @id @default(cuid())
  name            String
  categoryId      String
  category        ProductCategory @relation(fields: [categoryId], references: [id])
  description     String?
  basePrice       Decimal         @db.Decimal(12, 2)
  unit            String          @default("piece") // piece, sqft, sqm, sheet, roll
  minQuantity     Int             @default(1)
  leadTimeDays    Int             @default(1)
  isActive        Boolean         @default(true)
  priceTemplates  PriceTemplate[]
  orderItems      OrderItem[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([categoryId])
}

model PriceTemplate {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  name        String   // e.g. "Business Card 300gsm", "A4 Flyer"
  description String?
  options     Json     // Store configurable options: sizes, paper types, finishes
  basePrice   Decimal  @db.Decimal(12, 2)
  quantity1   Int      @default(100)
  price1      Decimal  @db.Decimal(12, 2)
  quantity2   Int      @default(500)
  price2      Decimal  @db.Decimal(12, 2)
  quantity3   Int      @default(1000)
  price3      Decimal  @db.Decimal(12, 2)
  quantity4   Int      @default(5000)
  price4      Decimal  @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  orderItems  OrderItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id])
  branchId        String?
  branch          Branch?     @relation(fields: [branchId], references: [id])
  status          OrderStatus @default(DRAFT)
  priority        Priority    @default(NORMAL)
  subtotal        Decimal     @default(0) @db.Decimal(12, 2)
  discount        Decimal     @default(0) @db.Decimal(12, 2)
  tax             Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal     @default(0) @db.Decimal(12, 2)
  notes           String?
  specialInstructions String?
  dueDate         DateTime?
  confirmedAt     DateTime?
  productionStartedAt DateTime?
  completedAt     DateTime?
  deliveredAt     DateTime?
  deliveryAddress String?
  deliveryMethod  String?     // pickup, delivery, courier
  createdBy       String
  creator         User?       @relation(fields: [createdBy], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
  invoices        Invoice[]
  proofs          Proof[]
  productionJobs  ProductionJob[]
  orderHistory    OrderHistory[]

  @@index([orderNumber])
  @@index([customerId])
  @@index([status])
  @@index([branchId])
  @@index([createdAt])
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  IN_PRODUCTION
  QUALITY_CHECK
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  ON_HOLD
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model OrderItem {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  priceTemplateId String?
  priceTemplate   PriceTemplate? @relation(fields: [priceTemplateId], references: [id])
  name            String        // Snapshot of product name
  description     String?
  quantity        Int
  unitPrice       Decimal       @db.Decimal(12, 2)
  discount        Decimal       @default(0) @db.Decimal(12, 2)
  totalPrice      Decimal       @db.Decimal(12, 2)
  specifications  Json?         // Paper size, type, finish, color mode, etc.
  fileUrl         String?       // Uploaded design file
  previewUrl      String?       // Generated preview
  status          OrderItemStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum OrderItemStatus {
  PENDING
  IN_PRODUCTION
  COMPLETED
  CANCELLED
}

model OrderHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id])
  status    OrderStatus
  notes     String?
  changedBy String
  createdAt DateTime    @default(now())
}

// ─── Inventory ───────────────────────────────────────────────────────────────

model MaterialCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  materials   Material[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Material {
  id              String          @id @default(cuid())
  name            String
  code            String          @unique
  categoryId      String
  category        MaterialCategory @relation(fields: [categoryId], references: [id])
  unit            String          @default("sheet") // sheet, roll, kg, liter, box
  description     String?
  minStockLevel   Int             @default(10)
  maxStockLevel   Int             @default(1000)
  reorderPoint    Int             @default(50)
  costPrice       Decimal         @db.Decimal(12, 2)
  branchId        String?
  branch          Branch?         @relation(fields: [branchId], references: [id])
  isActive        Boolean         @default(true)
  stockMovements  StockMovement[]
  supplierMaterials SupplierMaterial[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([code])
  @@index([categoryId])
}

model Warehouse {
  id          String   @id @default(cuid())
  name        String
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  address     String?
  isActive    Boolean  @default(true)
  stockMovements StockMovement[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StockMovement {
  id              String        @id @default(cuid())
  materialId      String
  material        Material      @relation(fields: [materialId], references: [id])
  warehouseId     String?
  warehouse       Warehouse?    @relation(fields: [warehouseId], references: [id])
  type            MovementType
  quantity        Int
  referenceType   String?       // "purchase", "production", "adjustment"
  referenceId     String?       // ID of related record
  notes           String?
  performedBy     String
  createdAt       DateTime      @default(now())
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
}

// ─── Suppliers ───────────────────────────────────────────────────────────────

model Supplier {
  id                  String             @id @default(cuid())
  name                String
  contactPerson       String?
  phone               String
  email               String?
  address             String?
  isActive            Boolean            @default(true)
  supplierMaterials   SupplierMaterial[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model SupplierMaterial {
  id           String   @id @default(cuid())
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  materialId   String
  material     Material @relation(fields: [materialId], references: [id])
  unitPrice    Decimal  @db.Decimal(12, 2)
  leadTimeDays Int      @default(3)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([supplierId, materialId])
}

// ─── Invoices & Payments ─────────────────────────────────────────────────────

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  orderId       String?
  order         Order?        @relation(fields: [orderId], references: [id])
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  subtotal      Decimal       @default(0) @db.Decimal(12, 2)
  tax           Decimal       @default(0) @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal       @db.Decimal(12, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(12, 2)
  dueAmount     Decimal       @db.Decimal(12, 2)
  status        InvoiceStatus @default(PENDING)
  dueDate       DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  payments      Payment[]

  @@index([invoiceNumber])
  @@index([customerId])
  @@index([status])
}

enum InvoiceStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

model Payment {
  id              String        @id @default(cuid())
  paymentNumber   String        @unique
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])
  amount          Decimal       @db.Decimal(12, 2)
  method          PaymentMethod
  reference       String?       // Transaction ID for digital payments
  notes           String?
  receivedBy      String
  paymentDate     DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([invoiceId])
  @@index([paymentNumber])
}

enum PaymentMethod {
  CASH
  BKASH
  NAGAD
  ROCKET
  BANK_TRANSFER
  CHEQUE
  ADVANCE
  OTHER
}

// ─── Proofs & Annotations ────────────────────────────────────────────────────

model Proof {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id])
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  orderItemId   String?
  version       Int           @default(1)
  fileUrl       String
  previewUrl    String?
  status        ProofStatus   @default(PENDING)
  notes         String?
  reviewedBy    String?
  reviewer      User?       @relation(fields: [reviewedBy], references: [id])
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  annotations   ProofAnnotation[]
  reviews       Proof[]       @relation("ProofRevisions")
  revisionOf    String?
  revisionOfProof Proof?      @relation("ProofRevisions", fields: [revisionOf], references: [id])
}

enum ProofStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_NEEDED
}

model ProofAnnotation {
  id          String   @id @default(cuid())
  proofId     String
  proof       Proof    @relation(fields: [proofId], references: [id])
  x           Float
  y           Float
  width       Float?
  height      Float?
  text        String
  color       String   @default("#FF0000")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Production Tracking ─────────────────────────────────────────────────────

model Machine {
  id          String          @id @default(cuid())
  name        String
  code        String          @unique
  type        String          // "digital_press", "offset", "cutter", "laminator"
  status      MachineStatus   @default(AVAILABLE)
  branchId    String?
  branch      Branch?         @relation(fields: [branchId], references: [id])
  jobs        ProductionJob[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum MachineStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  OUT_OF_SERVICE
}

model ProductionJob {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id])
  orderItemId   String?
  machineId     String?
  machine       Machine?      @relation(fields: [machineId], references: [id])
  operatorId    String?
  operator      User?         @relation(fields: [operatorId], references: [id])
  status        ProductionJobStatus @default(QUEUED)
  progress      Int           @default(0) // 0-100
  startedAt     DateTime?
  completedAt   DateTime?
  estimatedHours Float?
  actualHours   Float?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([operatorId])
  @@index([machineId])
}

enum ProductionJobStatus {
  QUEUED
  IN_PROGRESS
  PAUSED
  COMPLETED
  FAILED
}
